<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Acción que abre la vista de etiquetas de productos -->
        <record id="action_product_product_tag" model="ir.actions.act_window">
            <field name="name">Etiquetas de Productos</field>
            <field name="res_model">product.tag</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="product.product_tag_tree_view"/>
        </record>

        <!-- Menú dentro de Inventario > Configuración > Productos -->
        <menuitem id="menu_product_tags"
                  name="Etiquetas"
                  parent="stock.menu_product_in_config_stock"
                  action="action_product_product_tag"
                  sequence="30"/>

    </data>
</odoo>
