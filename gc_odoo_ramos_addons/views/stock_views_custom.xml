<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_product_tree_inherit_show_avg_cost_only_manager" model="ir.ui.view">
            <field name="name">product.product.tree.show_avg_cost.only.manager</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="stock_account.product_product_stock_tree_inherit_stock_account"/>
            <field name="arch" type="xml">
                <field name="avg_cost" position="replace">
                    <field name="avg_cost" 
                           string="Unit Cost" 
                           optional="show" 
                           widget="monetary" 
                           options="{'currency_field': 'company_currency_id'}"
                           groups="stock.group_stock_manager"/>
                </field>
            </field>
        </record>
    </data>
</odoo>
