<odoo>
    <data>
        <!-- Heredar el menú y asignar grupo -->
        <record id="sale.menu_product_pricelist_main" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
        </record>
        <record id="account.menu_finance" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [ref('account.group_account_manager')])]"/>
        </record>
        <menuitem
            id="custom_sales_reports_menu"
            name="Reportes"
            parent="sale.sale_menu_root"
            sequence="60"
            groups="sales_team.group_sale_salesman"
        />
        <!-- Duplicar Libro del Día -->
        <menuitem
            id="custom_menu_daybook_in_sales"
            name="Libro del Día"
            parent="custom_sales_reports_menu"
            action="om_account_daily_reports.action_account_daybook_menu"
            sequence="100"
            groups="sales_team.group_sale_salesman"
        />
        <!-- Duplicar Libro de Caja -->
        <menuitem
            id="custom_menu_cashbook_in_sales"
            name="Libro de Caja"
            parent="custom_sales_reports_menu"
            action="om_account_daily_reports.action_account_cashbook_menu"
            sequence="101"
            groups="sales_team.group_sale_salesman"
        />
        <!-- Duplicar Libro Banco -->
        <menuitem
            id="custom_menu_bankbook_in_sales"
            name="Libro Banco"
            parent="custom_sales_reports_menu"
            action="om_account_daily_reports.action_account_bankbook_menu"
            sequence="102"
            groups="sales_team.group_sale_salesman"
        />
    <record id="purchase.access_product_template_purchase_manager" model="ir.model.access">
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>
    <record id="sale.access_product_template_sale_manager" model="ir.model.access">
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>
    <record id="stock.access_product_template_stock_manager" model="ir.model.access">
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>
    <record id="account.access_product_template_account_manager" model="ir.model.access">
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>

    </data>
</odoo>
